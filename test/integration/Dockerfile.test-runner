# Test Runner Container
# Lightweight Alpine image with bash, curl, jq, yq for running
# YAML-driven integration tests against trace containers.
#
# Built as part of podman-compose.test.yml

FROM alpine:3.19

RUN apk add --no-cache \
    bash \
    curl \
    jq \
    coreutils \
    parallel

# Install yq (Go-based YAML processor, mikefarah version)
RUN ARCH=$(uname -m) && \
    case "$ARCH" in \
      x86_64) YQ_ARCH="amd64" ;; \
      aarch64) YQ_ARCH="arm64" ;; \
      *) echo "Unsupported arch: $ARCH" && exit 1 ;; \
    esac && \
    curl -sL "https://github.com/mikefarah/yq/releases/download/v4.44.1/yq_linux_${YQ_ARCH}" \
      -o /usr/local/bin/yq && \
    chmod +x /usr/local/bin/yq

WORKDIR /runner

# Copy test runner scripts
COPY run_tests.sh /runner/run_tests.sh
RUN chmod +x /runner/run_tests.sh

# Test definitions are mounted at /tests (from scripts/test_langs/)
# Container URLs are passed as environment variables

ENTRYPOINT ["/runner/run_tests.sh"]
